# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/business_management

# Security
SECRET_KEY=your-secret-key-change-this-in-production-min-32-characters-long
DEBUG=False

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# SMTP (for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Business Management Platform

# Two-Factor Authentication
TWO_FACTOR_ENABLED=False
