  ArrowLeft,
  Briefcase,
  MapPin,
  DollarSign,
  Clock,
  Users,
  Calendar,
  GraduationCap,
  Award,
  Globe,
  TrendingUp,
  CheckCircle,
  Edit,
  Share2,
  Trash2,
  FileText,
  Target,
  UserCheck,
  Send,
  Plus,
  X,
  Star,
  Megaphone,
  ClipboardList,
  Mail,
  Shield,
  MessageSquare,
  Video,
  ClipboardCheck,
  Eye,
  Upload,
  Image as ImageIcon,
  Filter,
  Trophy,
  Medal,
  AlertTriangle,
  Download,
} from "lucide-react";
import { ScheduleInterviewModal, CreateOfferModal, AssignRecruiterModal } from "@/components/recruitment/RecruitmentModals";
import {
  generateInterviewLetter,
  generateRegretLetter,
  generateOfferLetter,
  LetterPreviewModal,
  type LetterData
} from "@/components/recruitment/LetterTemplates";
