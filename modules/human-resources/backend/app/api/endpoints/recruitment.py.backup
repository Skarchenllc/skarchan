class UpdateStatusRequest(BaseModel):
    status: str
    current_stage: Optional[str] = None


@router.patch("/applicants/{applicant_id}/status")
async def update_applicant_status(applicant_id: str, request: UpdateStatusRequest, db: Session = Depends(get_db)):
    """Update applicant status"""

    valid_statuses = ["new", "screening", "interview", "offer", "hired", "rejected"]

    if request.status not in valid_statuses:
        raise HTTPException(status_code=400, detail=f"Invalid status. Must be one of: {', '.join(valid_statuses)}")

    try:
        applicant_uuid = uuid.UUID(applicant_id)
    except ValueError:
        raise HTTPException(status_code=400, detail="Invalid applicant ID format")

    db_applicant = db.query(Applicant).filter(Applicant.id == applicant_uuid).first()

    if not db_applicant:
        raise HTTPException(status_code=404, detail="Applicant not found")

    db_applicant.status = ApplicantStatus(request.status)
    if request.current_stage:
        db_applicant.current_stage = request.current_stage

    db.commit()
    db.refresh(db_applicant)

    return ApplicantResponse(
        id=str(db_applicant.id),
        application_date=db_applicant.application_date.strftime("%Y-%m-%d"),
        status=db_applicant.status.value,
        current_stage=db_applicant.current_stage,
        name=db_applicant.name,
        email=db_applicant.email,
        phone=db_applicant.phone,
        job_id=str(db_applicant.job_id),
        job_title=db_applicant.job_title,
        resume_url=db_applicant.resume_url,
        cv_file_name=db_applicant.cv_file_name,
        cover_letter=db_applicant.cover_letter,
        portfolio_url=db_applicant.portfolio_url,
        linkedin_url=db_applicant.linkedin_url,
        experience_years=db_applicant.experience_years,
        education=db_applicant.education,
        skills=db_applicant.skills,
        date_of_birth=db_applicant.date_of_birth.strftime("%Y-%m-%d") if db_applicant.date_of_birth else None,
        gender=db_applicant.gender,
        nationality=db_applicant.nationality,
        address=db_applicant.address,
        city=db_applicant.city,
        state=db_applicant.state,
        zip_code=db_applicant.zip_code,
        country=db_applicant.country,
        emergency_contact_name=db_applicant.emergency_contact_name,
        emergency_contact_phone=db_applicant.emergency_contact_phone,
        emergency_contact_relationship=db_applicant.emergency_contact_relationship
    )


@router.delete("/applicants/{applicant_id}")
async def delete_applicant(applicant_id: str, db: Session = Depends(get_db)):
    """Delete an applicant"""

    try:
        applicant_uuid = uuid.UUID(applicant_id)
    except ValueError:
        raise HTTPException(status_code=400, detail="Invalid applicant ID format")

    db_applicant = db.query(Applicant).filter(Applicant.id == applicant_uuid).first()

    if not db_applicant:
        raise HTTPException(status_code=404, detail="Applicant not found")

    job_id = db_applicant.job_id

    db.delete(db_applicant)
    db.commit()

    # Update job requisition applicants_count
    db_job = db.query(JobRequisition).filter(JobRequisition.id == job_id).first()
    if db_job:
        db_job.applicants_count = max(0, db_job.applicants_count - 1)
        db.commit()

    return {"message": "Applicant deleted successfully"}


# Convert Applicant to Employee
class ConvertToEmployeeRequest(BaseModel):
    applicant_id: str
    job_requisition_id: str
    start_date: str
    employee_code: Optional[str] = None
    department_id: Optional[str] = None
    base_salary: Optional[float] = None
    pay_frequency: Optional[str] = "bi_weekly"
    employment_type: Optional[str] = "full_time"
    probation_days: int = 90


@router.post("/applicants/convert-to-employee")
async def convert_applicant_to_employee(request: ConvertToEmployeeRequest, db: Session = Depends(get_db)):
    """Convert a hired applicant to an employee in the HR system"""

    # Find the applicant
    try:
        applicant_uuid = uuid.UUID(request.applicant_id)
    except ValueError:
        raise HTTPException(status_code=400, detail="Invalid applicant ID format")

    db_applicant = db.query(Applicant).filter(Applicant.id == applicant_uuid).first()

    if not db_applicant:
        raise HTTPException(status_code=404, detail="Applicant not found")

    # Verify applicant status is "hired"
    if db_applicant.status != ApplicantStatus.HIRED:
        raise HTTPException(
            status_code=400,
            detail="Only hired applicants can be converted to employees"
        )

    # Find job requisition for additional details
    try:
        job_req_uuid = uuid.UUID(request.job_requisition_id)
    except ValueError:
        raise HTTPException(status_code=400, detail="Invalid job requisition ID format")

    db_job = db.query(JobRequisition).filter(JobRequisition.id == job_req_uuid).first()

    if not db_job:
        raise HTTPException(status_code=404, detail="Job requisition not found")

    # Generate employee code if not provided
    employee_code = request.employee_code
    if not employee_code:
        year = datetime.now().year
        # Count existing employees to generate sequential code
        applicant_count = db.query(Applicant).count()
        employee_code = f"EMP-{year}-{applicant_count:04d}"

    # Calculate probation end date
    start_date_obj = datetime.strptime(request.start_date, "%Y-%m-%d")
    probation_end_date = (start_date_obj + timedelta(days=request.probation_days)).strftime("%Y-%m-%d")

    # Parse applicant name into first and last name
    name_parts = db_applicant.name.split(" ", 1)
    first_name = name_parts[0]
    last_name = name_parts[1] if len(name_parts) > 1 else ""

    # Prepare employee data
    employee_data = {
        "employee_code": employee_code,
        "first_name": first_name,
        "last_name": last_name,
        "work_email": db_applicant.email,
        "work_phone": db_applicant.phone,
        "employment_type": (request.employment_type or db_job.employment_type).lower(),
        "employment_status": "on_probation",
        "job_title": db_applicant.job_title,
        "hire_date": request.start_date,
        "base_salary": request.base_salary,
        "pay_frequency": request.pay_frequency,
        # Only include department_id if it has a value
        **({"department_id": request.department_id} if request.department_id else {}),
        # Personal info from applicant (only include if not None)
        **({"date_of_birth": db_applicant.date_of_birth.strftime("%Y-%m-%d")} if db_applicant.date_of_birth else {}),
        **({"gender": db_applicant.gender} if db_applicant.gender else {}),
        **({"nationality": db_applicant.nationality} if db_applicant.nationality else {}),
        **({"address": db_applicant.address} if db_applicant.address else {}),
        **({"city": db_applicant.city} if db_applicant.city else {}),
        **({"state": db_applicant.state} if db_applicant.state else {}),
        **({"zip_code": db_applicant.zip_code} if db_applicant.zip_code else {}),
        **({"country": db_applicant.country} if db_applicant.country else {}),
        # Emergency contact (only include if not None)
        **({"emergency_contact_name": db_applicant.emergency_contact_name} if db_applicant.emergency_contact_name else {}),
        **({"emergency_contact_phone": db_applicant.emergency_contact_phone} if db_applicant.emergency_contact_phone else {}),
        **({"emergency_contact_relationship": db_applicant.emergency_contact_relationship} if db_applicant.emergency_contact_relationship else {})
    }

    # Call HR backend API to create employee
    try:
        async with httpx.AsyncClient() as client:
            response = await client.post(
                "http://hr-backend:8000/api/v1/employees",
                json=employee_data,
                timeout=30.0
            )

            if response.status_code == 200 or response.status_code == 201:
                employee = response.json()

                # Update applicant with converted flag
                db_applicant.converted_to_employee = True
                db_applicant.employee_id = uuid.UUID(employee.get("id")) if employee.get("id") else None
                db_applicant.conversion_date = datetime.now().date()
                db.commit()

                return {
                    "message": "Applicant successfully converted to employee",
                    "employee_id": employee.get("id"),
                    "employee_code": employee_code,
                    "onboarding_initiated": True,
                    "employee_data": employee
                }
            else:
                error_detail = response.text
                raise HTTPException(
                    status_code=response.status_code,
                    detail=f"Failed to create employee in HR system: {error_detail}"
                )

    except httpx.RequestError as e:
        raise HTTPException(
            status_code=500,
            detail=f"Failed to connect to HR system: {str(e)}"
        )


@router.get("/applicants/hired", response_model=List[ApplicantResponse])
async def get_hired_applicants(db: Session = Depends(get_db)):
    """Get all hired applicants (ready to be converted to employees)"""

    hired_applicants = db.query(Applicant).filter(
        Applicant.status == ApplicantStatus.HIRED,
        Applicant.converted_to_employee == False
    ).all()

    # Convert to response format
    result = []
    for db_applicant in hired_applicants:
        result.append(ApplicantResponse(
            id=str(db_applicant.id),
            application_date=db_applicant.application_date.strftime("%Y-%m-%d"),
            status=db_applicant.status.value,
            current_stage=db_applicant.current_stage,
            name=db_applicant.name,
            email=db_applicant.email,
            phone=db_applicant.phone,
